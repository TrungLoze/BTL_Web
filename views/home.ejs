<%- include('layouts/header') %>
    <link rel="stylesheet" href="/css/home.css">
    <div class="container flex-grow-1 py-4 d-flex flex-column gap-4 overflow-auto">
        <section class="hero-banner p-5 rounded-4 text-white flex-shrink-0">
            <div class="hero-badge d-inline-block px-3 py-2 rounded-pill mb-4 border border-light border-opacity-25">⚡ Gia nhập hơn 1 triệu học sinh trên toàn quốc</div>
            <h1 class="hero-title display-4 fw-bold mb-4">Box-Fed <br><span class="text-danger">HUST.</span></h1>
            <p class="hero-desc text-light mb-4">Hệ thống các khóa học trực tuyến sử dụng công cụ đặc biệt dành riêng cho sinh viên
                ngành công nghệ giáo dục</p>
            <div class="d-flex align-items-center gap-3">
                <button class="btn-discover btn btn-danger px-4 py-2 fw-bold">KHÁM PHÁ KHÓA HỌC &rarr;</button>
                <button class="btn-play btn btn-outline-light rounded-circle d-flex justify-content-center align-items-center">▶</button>
            </div>
        </section>

        <h2 class="mt-2 fw-bold">Khóa học nổi bật</h2>

        <div class="card" style="width: 18rem;">
            <img src="https://images.unsplash.com/photo-1606326608606-aa0b62935f2b?q=80&w=600&auto=format&fit=crop"
                class="card-img-top" alt="Khóa học Quizizz">
            <div class="card-body">
                <h5 class="card-title">Khóa học Quizizz Cơ bản</h5>
                <p class="card-text">Hướng dẫn tạo bài trắc nghiệm tương tác cho lớp học.</p>
                <a href="#" class="btn btn-primary">Bắt đầu học ngay</a>
            </div>
        </div>
    </div>
    <%- include('layouts/footer') %>