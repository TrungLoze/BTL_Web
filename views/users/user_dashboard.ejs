<%- include('../layouts/header') %>
<link rel="stylesheet" href="/css/admin.css">
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-people-fill text-primary me-2"></i> Quản Lý Người Dùng</h2>
            <p class="text-muted mb-0">Quản lý và phân quyền tài khoản thành viên hệ thống.</p>
        </div>
        <div>
            <a href="/users/dashboard/rebin" class="btn btn-outline-danger fw-bold rounded-pill px-4 shadow-sm">
                <i class="bi bi-trash3 me-1"></i> Thùng rác
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-4 sortable" onclick="sortTable(0, 'number')" title="Sắp xếp theo ID">ID <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8rem;"></i></th>
                            <th scope="col">Họ và tên</th>
                            <th scope="col">Email</th>
                            <th scope="col">Vai trò</th>
                            <th scope="col" class="sortable" onclick="sortTable(4, 'number')" title="Sắp xếp theo số khóa học">Khóa học <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8rem;"></i></th>
                            <th scope="col" class="sortable" onclick="sortTable(5, 'number')" title="Sắp xếp theo ngày tham gia">Ngày tham gia <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8rem;"></i></th>
                            <th scope="col" class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(userItem => { %>
                                <tr>
                                    <td class="ps-4 text-muted fw-bold" data-value="<%= userItem.id %>">#<%= userItem.id %></td>
                                    <td>
                                        <div class="fw-bold text-dark"><%= userItem.full_name %></div>
                                    </td>
                                    <td>
                                        <a href="mailto:<%= userItem.email %>" class="text-decoration-none text-muted"><%= userItem.email %></a>
                                    </td>
                                    <td>
                                        <% if (userItem.role === 'admin') { %>
                                            <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-shield-lock-fill me-1"></i> Admin</span>
                                        <% } else { %>
                                            <span class="badge bg-info text-dark rounded-pill px-3 py-2"><i class="bi bi-person-fill me-1"></i> Học viên</span>
                                        <% } %>
                                    </td>
                                    <td data-value="<%= userItem.enrollments ? userItem.enrollments.length : 0 %>">
                                        <% if (userItem.enrollments && userItem.enrollments.length > 0) { %>
                                            <button class="btn btn-sm btn-outline-primary rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#userCoursesModal<%= userItem.id %>">
                                                <i class="bi bi-journal-bookmark me-1"></i> <%= userItem.enrollments.length %> khóa học
                                            </button>
                                            
                                            <!-- Modal Danh sách khóa học -->
                                            <div class="modal fade" id="userCoursesModal<%= userItem.id %>" tabindex="-1" aria-labelledby="userCoursesModalLabel<%= userItem.id %>" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered modal-lg">
                                                    <div class="modal-content border-0 shadow">
                                                        <div class="modal-header bg-light">
                                                            <h5 class="modal-title fw-bold text-dark" id="userCoursesModalLabel<%= userItem.id %>"><i class="bi bi-book-half text-primary me-2"></i> Tiến độ học tập của <%= userItem.full_name %></h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <div class="modal-body p-0">
                                                            <div class="list-group list-group-flush">
                                                                <% userItem.enrollments.forEach(course => { %>
                                                                    <% const progress = course.total_lessons > 0 ? Math.round((course.completed_lessons / course.total_lessons) * 100) : 0; %>
                                                                    <div class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-md-center p-4">
                                                                        <div class="d-flex align-items-center mb-3 mb-md-0">
                                                                            <img src="<%= course.cover_image %>" class="rounded-3 shadow-sm me-3" style="width: 80px; height: 60px; object-fit: cover;">
                                                                            <div>
                                                                                <h6 class="mb-1 fw-bold text-dark"><%= course.title %></h6>
                                                                                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> Đăng ký: <%= new Date(course.enrolled_at).toLocaleDateString('vi-VN') %></small>
                                                                            </div>
                                                                        </div>
                                                                        <div class="text-end" style="min-width: 200px;">
                                                                            <div class="d-flex justify-content-between mb-1">
                                                                                <small class="fw-bold text-muted">Tiến độ (<%= course.completed_lessons %>/<%= course.total_lessons %>)</small>
                                                                                <small class="text-<%= progress === 100 ? 'success' : 'primary' %> fw-bold"><%= progress %>%</small>
                                                                            </div>
                                                                            <div class="progress" style="height: 10px; border-radius: 10px;">
                                                                                <div class="progress-bar <%= progress === 100 ? 'bg-success' : 'bg-primary progress-bar-striped progress-bar-animated' %>" role="progressbar" aria-valuenow="<%= progress %>" aria-valuemin="0" aria-valuemax="100"></div>
                                                                            </div>
                                                                            <% if (progress === 100) { %>
                                                                                <div class="mt-2 text-success small fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Đã hoàn thành</div>
                                                                            <% } else if (progress > 0) { %>
                                                                                <div class="mt-2 text-primary small fw-bold"><i class="bi bi-arrow-clockwise me-1"></i> Đang học</div>
                                                                            <% } else { %>
                                                                                <div class="mt-2 text-muted small fw-bold"><i class="bi bi-dash-circle me-1"></i> Chưa bắt đầu</div>
                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                <% }) %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted small"><i class="bi bi-dash"></i> 0 khóa học</span>
                                        <% } %>
                                    </td>
                                    <td data-value="<%= new Date(userItem.created_at).getTime() %>">
                                        <small class="text-muted"><%= new Date(userItem.created_at).toLocaleDateString('vi-VN') %></small>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/users/<%= userItem.id %>/edit" class="btn btn-sm btn-outline-primary border-0 rounded-circle me-1" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </a>
                                        <% if (userItem.id !== user.id) { %>
                                        <form action="/users/<%= userItem.id %>/delete" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Xóa tài khoản" onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này không?');">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </form>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-outline-secondary border-0 rounded-circle disabled" title="Không thể xóa chính mình">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    Chưa có người dùng nào.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Gán chiều rộng cho thanh tiến độ dựa trên thuộc tính aria-valuenow để tránh lỗi CSS linter trong file EJS
        const progressBars = document.querySelectorAll('.progress-bar');
        progressBars.forEach(bar => {
            const val = bar.getAttribute('aria-valuenow');
            if (val !== null) {
                bar.style.width = val + '%';
            }
        });
    });

    // Tính năng sắp xếp bảng
    let sortDirections = [true, true, true, true, true, true]; // true = tăng dần, false = giảm dần
    function sortTable(colIndex, type) {
        const table = document.querySelector(".table tbody");
        const rows = Array.from(table.querySelectorAll("tr"));
        
        // Nếu không có dữ liệu thì không sort
        if (rows.length <= 1 && rows[0].querySelector("td").colSpan > 1) return;

        const isAsc = sortDirections[colIndex];
        sortDirections[colIndex] = !isAsc; // Đảo chiều cho lần click sau

        rows.sort((a, b) => {
            let valA = a.querySelectorAll("td")[colIndex].getAttribute("data-value");
            let valB = b.querySelectorAll("td")[colIndex].getAttribute("data-value");
            
            if (type === 'number') {
                valA = parseFloat(valA) || 0;
                valB = parseFloat(valB) || 0;
                return isAsc ? valA - valB : valB - valA;
            }
            return isAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        });

        // Xóa tbody cũ và append lại các row đã sort
        rows.forEach(row => table.appendChild(row));
    }
</script>

<%- include('../layouts/footer') %>
